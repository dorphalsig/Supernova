<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/supernova_bg"
    android:orientation="horizontal"
    android:padding="@dimen/padding_xlarge">

    <!-- Left side - Loading Animation -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingEnd="@dimen/margin_xlarge">

        <ImageView
            android:id="@+id/loadingAnimationImageView"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:contentDescription="@string/loading_animation"
            android:scaleType="centerInside"
            android:src="@drawable/loading_animation" />

    </LinearLayout>

    <!-- Right side - Text Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_xlarge">

        <!-- Title -->
        <TextView
            android:id="@+id/setupTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_xlarge"
            android:text="@string/finishing_setup"
            android:textColor="@color/supernova_on_surface"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Rotating Phrase -->
        <TextView
            android:id="@+id/loadingPhraseTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/supernova_on_surface_var"
            android:textSize="@dimen/tv_text_size_large" />

    </LinearLayout>

</LinearLayout>