<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileCard"
    android:layout_width="@dimen/profile_card_width"
    android:layout_height="@dimen/profile_card_height"
    android:layout_margin="@dimen/margin_medium"
    android:focusable="true"
    android:focusableInTouchMode="true"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/card_background"
    app:strokeColor="@color/purple_500"
    app:strokeWidth="0dp"
    style="@style/Widget.Supernova.Card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/padding_large">

        <!-- Profile Avatar -->
        <ImageView
            android:id="@+id/profileAvatarImageView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/profile_avatar"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.7" />

        <!-- Lock Indicator -->
        <ImageView
            android:id="@+id/lockIndicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            app:tint="@color/white"
            android:background="@drawable/lock_background"
            android:padding="6dp"
            android:visibility="gone"
            android:contentDescription="@string/profile_has_pin"
            app:layout_constraintEnd_toEndOf="@id/profileAvatarImageView"
            app:layout_constraintTop_toTopOf="@id/profileAvatarImageView" />

        <!-- Profile Name -->
        <TextView
            android:id="@+id/profileNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center"
            android:text="@string/profile_name"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_text_size_large"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileAvatarImageView"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.3" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>