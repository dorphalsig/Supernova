<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme for Supernova -->
    <style name="Theme.Supernova" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/supernova_primary</item>
        <item name="colorPrimaryVariant">@color/supernova_primary_cont</item>
        <item name="colorOnPrimary">@color/supernova_on_surface</item>

        <item name="colorSecondary">@color/supernova_focus</item>
        <item name="colorSecondaryVariant">@color/supernova_primary_cont</item>
        <item name="colorOnSecondary">@color/supernova_bg</item>

        <item name="colorSurface">@color/supernova_surface</item>
        <item name="colorOnSurface">@color/supernova_on_surface</item>
        <item name="android:colorBackground">@color/supernova_bg</item>
        <item name="colorOnBackground">@color/supernova_on_surface</item>

        <!-- TV Optimizations -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <!-- Compose Theme -->
    <style name="Theme.Supernova.Compose" parent="Theme.Supernova">
        <!-- Enable edge-to-edge for Compose -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.Supernova.Splash" parent="Theme.Supernova">
        <item name="android:windowBackground">@color/supernova_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.Supernova.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/tv_button_height</item>
        <item name="android:minWidth">@dimen/tv_button_width</item>
        <item name="android:textSize">@dimen/tv_text_size</item>
        <item name="android:padding">@dimen/tv_button_padding</item>
    </style>

    <!-- EditText Styles -->
    <style name="Widget.Supernova.EditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:minHeight">@dimen/tv_input_height</item>
        <item name="android:textSize">@dimen/tv_text_size</item>
        <item name="android:padding">@dimen/tv_input_padding</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.Supernova.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>
</resources>